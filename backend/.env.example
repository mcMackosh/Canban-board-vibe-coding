# Backend environment configuration (copy to .env and fill in real values).

# Prisma / SQLite database location (relative to the prisma/ directory).
DATABASE_URL="file:./dev.db"

# JWT signing secret — use a long random string in real environments.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# HTTP server port.
PORT=4000

# Allowed CORS origin (the frontend dev server).
CORS_ORIGIN="http://localhost:5173"
